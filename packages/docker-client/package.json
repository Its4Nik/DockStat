{
  "author": "Its4Nik",
  "bugs": {
    "url": "https://github.com/Its4Nik/DockStat/issues"
  },
  "dependencies": {
    "@dockstat/docker": "workspace:*",
    "@dockstat/logger": "workspace:*",
    "@dockstat/plugin-handler": "workspace:*",
    "@dockstat/sqlite-wrapper": "workspace:*",
    "@dockstat/typings": "workspace:*",
    "@dockstat/utils": "workspace:*",
    "@types/dockerode": "catalog:docker",
    "dockerode": "catalog:docker"
  },
  "description": "A docker-client library powered by Dockerode for DockStat",
  "devDependencies": {
    "bun-types": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "exports": {
    ".": "./src/manager/index.ts",
    "./client": "./src/client/index.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "index.ts",
    "src",
    "README.md"
  ],
  "homepage": "https://github.com/Its4Nik/DockStat/tree/main/packages/docker-client",
  "main": "./src/manager/index.ts",
  "name": "@dockstat/docker-client",
  "peerDependencies": {
    "typescript": "catalog:testing"
  },
  "repository": {
    "directory": "packages/docker-client",
    "type": "git",
    "url": "https://github.com/Its4Nik/DockStat"
  },
  "scripts": {
    "check-types": "bunx tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "bun run --watch index.ts",
    "example:basic": "bun run examples/basic-usage.ts",
    "example:websocket": "bun run examples/websocket-integration.ts",
    "format": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:gh": "turbo run lint -- --reporter=github",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "bun run test.ts"
  },
  "type": "module",
  "types": "./src/manager/index.ts",
  "version": "2.0.1"
}
