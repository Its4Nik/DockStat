    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "bin": {
    "dockstat-repo": "./dist/dockstat-repo-cli"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@dockstat/utils": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.2"
  },
  "description": "A CLI helper for administering DockStat Repositories",
  "devDependencies": {
    "@dockstat/typings": "workspace:*",
    "bun-types": "latest"
  },
  "exports": {
    "./types": "./src/types.ts"
  },
  "keywords": [
    "dockstat",
    "cli",
    "repository",
    "admin",
    "bun"
  ],
  "license": "MPL-2.0",
  "module": "src/index.ts",
  "name": "@dockstat/repo-cli",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "directory": "packages/repo-cli",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "build": "bun build --target=bun --compile --outfile=dist/dockstat-repo-cli src/index.ts",
    "publish": "bun run build && bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "version": "1.0.5"
}
