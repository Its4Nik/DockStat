{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "tsBuildInfoFile": ".tsbuildinfo.node"
  },
  "include": ["vite.config.ts"]
}
