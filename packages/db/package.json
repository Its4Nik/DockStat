{
  "dependencies": {
    "@dockstat/typings": "workspace:*",
    "bun-plugin-dts": "catalog:build-tools"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "files": [
    "./defaults.ts",
    "./index.ts"
  ],
  "main": "./index.ts",
  "name": "@dockstat/db",
  "peerDependencies": {
    "@dockstat/logger": "workspace:*",
    "@dockstat/sqlite-wrapper": "workspace:*",
    "typescript": "catalog:testing"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "check-types": "bunx tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "bun build index.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:gh": "turbo run lint -- --reporter=github",
    "test": "bun run test.ts"
  },
  "type": "module",
  "types": "./index.ts",
  "version": "1.0.0"
}
