{
  "author": {
    "email": "info@itsnik.de",
    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "dependencies": {
    "@types/chalk": "^2.2.4",
    "@types/source-map-support": "^0.5.10",
    "chalk": "^5.6.2",
    "source-map-support": "^0.5.21"
  },
  "description": "The (basic) internal logging service used by DockStat and @dockstat/outline-sync",
  "devDependencies": {
    "bun-types": "latest"
  },
  "exports": {
    ".": "./src/Logger.ts"
  },
  "keywords": [
    "dockstat",
    "logger",
    "logging",
    "bun"
  ],
  "license": "MPL-2.0",
  "main": "./src/Logger.ts",
  "module": "./src/Logger.ts",
  "name": "@dockstat/logger",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "directory": "packages/logger",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "check-types": "bunx tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:gh": "turbo run lint -- --reporter=github",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "types": "./src/Logger.ts",
  "version": "2.0.1"
}
