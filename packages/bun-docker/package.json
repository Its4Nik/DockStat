{
  "author": {
    "email": "info@itsnik.de",
    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "description": "A bun native, typesafe wrapper for the docker API",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bun-types": "latest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./spec": "./src/v1.54.d.ts"
  },
  "keywords": [
    "docker",
    "bun"
  ],
  "license": "MPL-2.0",
  "module": "src/index.ts",
  "name": "@dockstat/docker",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "directory": "packages/bun-docker",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "build": "bun build --target=bun --production --outdir=dist src/index.ts",
    "openapi": "bunx openapi-typescript ./.openapi-spec/v1.54.yaml -o ./.openapi-spec/v1.54.d.ts",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "version": "0.1.7"
}
