{
  "author": {
    "email": "info@itsnik.de",
    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "dependencies": {
    "@dockstat/sqlite-wrapper": "workspace:^",
    "@dockstat/typings": "workspace:^"
  },
  "description": "Type-safe plugin builder utilities for DockStat plugins",
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "catalog:testing"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "keywords": [
    "dockstat",
    "plugin",
    "builder",
    "typescript",
    "type-safe",
    "bun"
  ],
  "license": "MPL-2.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "name": "@dockstat/plugin-builder",
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "repository": {
    "directory": "packages/plugin-builder",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "format": "biome format --write",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "types": "src/index.ts",
  "version": "1.0.9"
}
