{
  "bin": {
    "outline-sync": "dist/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "front-matter": "^4.0.2",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "bun-types": "latest"
  },
  "files": [
    "./dist/index.js",
    "./README.md"
  ],
  "main": "dist/index.js",
  "name": "@dockstat/outline-sync",
  "scripts": {
    "build": "rm -r dist && bun build src/index.ts --outdir dist --target bun --banner '#!/usr/bin/env bun'",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build",
    "sync": "bun run src/index.ts sync",
    "watch": "bun run src/index.ts watch"
  },
  "type": "module",
  "version": "1.3.0"
}
