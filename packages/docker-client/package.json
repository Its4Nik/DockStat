{
  "author": {
    "email": "info@itsnik.de",
    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "dependencies": {
    "@dockstat/docker": "workspace:*",
    "@dockstat/logger": "workspace:*",
    "@dockstat/plugin-handler": "workspace:*",
    "@dockstat/sqlite-wrapper": "workspace:*",
    "@dockstat/typings": "workspace:*",
    "@dockstat/utils": "workspace:*",
    "@types/dockerode": "catalog:docker",
    "dockerode": "catalog:docker"
  },
  "description": "A docker-client library powered by Dockerode for DockStat",
  "devDependencies": {
    "bun-types": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "exports": {
    ".": "./src/manager/index.ts",
    "./client": "./src/client/index.ts",
    "./types": "./src/types.ts"
  },
  "keywords": [
    "docker",
    "dockerode",
    "dockstat",
    "containers",
    "bun"
  ],
  "license": "MPL-2.0",
  "main": "./src/manager/index.ts",
  "name": "@dockstat/docker-client",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "directory": "packages/docker-client",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "check-types": "bunx tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "bun run --watch index.ts",
    "format": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:gh": "turbo run lint -- --reporter=github",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "types": "./src/manager/index.ts",
  "version": "2.0.4"
}
