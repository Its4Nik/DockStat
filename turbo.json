{
  "$schema": "./node_modules/turbo/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalPassThroughEnv": [
    "API_KEY",
    "API_KEYS_ENABLED",
    "AUTH_ENABLED",
    "BASE_URL",
    "CA_FILE",
    "CERT_FILE",
    "CRYPTO_SECRET",
    "DOCKSTAT_API_PORT",
    "DOCKSTAT_DB_BACKUP_INTERVAL",
    "DOCKSTAT_LOGGER_DISABLED_LOGGERS",
    "DOCKSTAT_LOGGER_FULL_FILE_PATH",
    "DOCKSTAT_LOGGER_IGNORE_MESSAGES",
    "DOCKSTAT_LOGGER_LEVEL",
    "DOCKSTAT_LOGGER_ONLY_SHOW",
    "DOCKSTAT_LOGGER_SEPERATOR",
    "DOCKSTAT_MAX_DB_BACKUPS",
    "DOCKSTAT_MAX_WORKERS",
    "DOCKSTAT_VERSION",
    "DOCKER_API_VERSION",
    "DOCKER_BIN_PATH",
    "DOCKER_CLIENT_LOG_LEVEL",
    "DOCKER_HOST",
    "DOCKER_SOCKET",
    "DOCKER_SOCKET_PATH",
    "DOCKNODE_DOCKSTACK_AUTH_PSK",
    "DOCKNODE_DOCKSTACK_AUTH_PRIORITY",
    "DOCKNODE_DOCKSTACK_DEV_AUTH",
    "DOCKSTATAPI_PORT",
    "DOCKSTATAPI_SHOW_TRACES",
    "FRONTEND_URL",
    "JWT_SECRET",
    "KEY_FILE",
    "NODE_ENV",
    "OIDC_CLIENT_ID",
    "OIDC_CLIENT_SECRET",
    "OIDC_ISSUER",
    "OIDC_REDIRECT_URI",
    "OIDC_SCOPE",
    "OUTLINE_CONFIG",
    "OUTLINE_OUTPUT_DIR",
    "OUTLINE_TOKEN",
    "OUTLINE_URL",
    "PLUGIN_API_KEY",
    "PLUGIN_ENDPOINT",
    "SECRET",
    "VERIFICATION_DB_PATH",
    "VERIFICATION_PORT",
    "VITE_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "check-types": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputLogs": "errors-only",
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "publish": {},
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    }
  }
}
