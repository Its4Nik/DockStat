{
  "author": {
    "email": "info@itsnik.de",
    "name": "ItsNik",
    "url": "https://itsnik.de"
  },
  "bin": {
    "outline-sync": "dist/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "front-matter": "^4.0.2",
    "yaml": "^2.3.4"
  },
  "description": "A CLI tool for syncing Outline documents to local markdown files",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "bun-types": "latest"
  },
  "keywords": [
    "outline",
    "sync",
    "markdown",
    "cli",
    "dockstat",
    "bun"
  ],
  "license": "MPL-2.0",
  "main": "dist/index.js",
  "name": "@dockstat/outline-sync",
  "repository": {
    "directory": "packages/outline-sync",
    "type": "git",
    "url": "https://github.com/its4nik/dockstat"
  },
  "scripts": {
    "build": "rm -r dist && bun build src/index.ts --outdir dist --target bun --banner '#!/usr/bin/env bun'",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build",
    "sync": "bun run src/index.ts sync",
    "watch": "bun run src/index.ts watch"
  },
  "type": "module",
  "version": "1.3.1"
}
