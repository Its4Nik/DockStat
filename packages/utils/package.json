{
  "dependencies": {
    "@tanstack/react-query": "catalog:react-ui"
  },
  "description": "A tiny utils library used in DockStat",
  "devDependencies": {
    "@dockstat/logger": "workspace:*",
    "@dockstat/typings": "workspace:*",
    "bun-types": "latest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react/index.ts"
  },
  "main": "src/index.ts",
  "name": "@dockstat/utils",
  "peerDependencies": {
    "typescript": "catalog:testing"
  },
  "private": false,
  "scripts": {
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "version": "1.0.1"
}
