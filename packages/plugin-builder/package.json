{
  "author": {
    "email": "dockstat@itsnik.de",
    "name": "Its4Nik",
    "url": "https://itsnik.de"
  },
  "dependencies": {
    "@dockstat/sqlite-wrapper": "workspace:^",
    "@dockstat/typings": "workspace:^"
  },
  "description": "Type-safe plugin builder utilities for DockStat plugins",
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "catalog:testing"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/index.ts",
    "README.md"
  ],
  "keywords": [
    "dockstat",
    "plugin",
    "builder",
    "typescript",
    "type-safe"
  ],
  "license": "MIT",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "name": "@dockstat/plugin-builder",
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "repository": {
    "directory": "packages/plugin-builder",
    "type": "git",
    "url": "https://github.com/Its4Nik/DockStat"
  },
  "scripts": {
    "format": "biome format --write",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "type": "module",
  "types": "src/index.ts",
  "version": "1.0.8"
}
