  },
  "dependencies": {
    "elysia": "catalog:",
    "js-yaml": "catalog:utils"
  },
  "devDependencies": {
    "@dockstat/docker": "workspace:*",
    "@dockstat/logger": "workspace:*",
    "@dockstat/sqlite-wrapper": "workspace:*",
    "@types/dockerode": "catalog:docker",
    "bun-types": "latest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/typebox/_schemas.ts",
    "./types": "./src/typebox/_types.ts",
    "./v2": "./src/v2/index.ts"
  },
  "name": "@dockstat/typings",
  "peerDependencies": {
    "typescript": "catalog:testing"
  },
  "private": false,
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:gh": "turbo run lint -- --reporter=github",
    "publish": "bun pm pack --destination ./dist && npm publish --access public ./dist/*.tgz ; rm -r ./dist"
  },
  "version": "1.1.2"
}
